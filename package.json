{
  "name": "lease-plain",
  "version": "1.0.0",
  "description": "Your lease, translated into English.",
  "private": true,
  "scripts": {
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:js": "eslint \"js/**/*.js\" \"netlify/functions/**/*.js\"",
    "lint:html": "html-validate index.html",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.html": [
      "html-validate",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint": "^10.7.0",
    "html-validate": "^11.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "netlify-cli": "^26.2.0",
    "prettier": "^3.9.6",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1"
  }
}
